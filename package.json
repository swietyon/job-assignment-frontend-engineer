{
  "name": "@kalamba/job-assignment-frontend-engineer",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "description": "Frontend skeleton for frontend engineer job assignment",
  "main": "index.js",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "tailwind:build": "tailwindcss -c ./tailwind.config.js -i ./src/styles.css -o ./src/tailwind.css",
    "prestart": "npm run tailwind:build",
    "start": "NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "prebuild": "npm run tailwind:build",
    "build": "NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "lint": "eslint --ext .ts,.tsx src",
    "prepare": "husky install",
    "test": "react-scripts test"
  },
  "dependencies": {
    "@types/jest": "27.0.2",
    "@types/node": "14.17.3",
    "@types/react": "17.0.30",
    "@types/react-dom": "17.0.9",
    "@types/react-router-dom": "5.3.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-router-dom": "^5.3.0",
    "react-scripts": "4.0.3",
    "typescript": "4.4.4",
    "web-vitals": "2.1.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "5.14.1",
    "@testing-library/react": "12.1.2",
    "@testing-library/user-event": "13.4.1",
    "@typescript-eslint/eslint-plugin": "4.31.2",
    "@typescript-eslint/parser": "4.31.2",
    "autoprefixer": "^10.5.2",
    "eslint": "7.32.0",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-prettier": "4.0.0",
    "eslint-plugin-react": "7.26.1",
    "eslint-plugin-react-hooks": "4.2.0",
    "husky": "7.0.2",
    "lint-staged": "11.2.3",
    "postcss": "^8.5.16",
    "prettier": "2.4.1",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "postcss-safe-parser": "6.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
